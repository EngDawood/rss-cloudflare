{
	"name": "rss-bridge",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "pnpm run build && wrangler deploy && node scripts/notify-deploy.js",
		"dev:backend": "wrangler dev",
		"dev:app": "vite app",
		"dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:app\"",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"build": "tsc -p app/tsconfig.app.json && vite build app",
		"preview": "vite preview app",
		"types": "wrangler types",
		"lint": "eslint app"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@eslint/js": "^10.0.1",
